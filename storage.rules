rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow public read access to all assets
      allow read: if true;

      // Allow write access only to Admin and Receptionist roles
      // Note: role check requires firestore lookup which isn't directly supported in Storage Rules without Custom Claims
      // For now, we allow authenticated users to upload to specific folders if needed, or Admin for everything.
      allow write: if request.auth != null;
    }
  }
}
